--!nocheck

--// Imports

local io = require("@lune/stdio")
local fs = require("@lune/fs")
local serde = require("@lune/serde")
local ui = require("./ui")

--// Constants

local EDITOR_PRESETS = {
	["VS Code"]  = { command = "code",   args = { "--wait", "{file}" } },
	["Cursor"]   = { command = "cursor", args = { "--wait", "{file}" } },
	["Neovim"]   = { command = "nvim",   args = { "{file}" } },
	["Zed"]      = { command = "zed",    args = { "--wait", "{file}" } },
	["Skip"]     = nil,
}

local EDITOR_OPTIONS = { "VS Code", "Cursor", "Neovim", "Zed", "Skip" }

local OPEN_PRESETS = {
	["VS Code"]  = { command = "code",   args = { "{file}" } },
	["Cursor"]   = { command = "cursor", args = { "{file}" } },
	["Neovim"]   = { command = "nvim",   args = { "{file}" } },
	["Zed"]      = { command = "zed",    args = { "{file}" } },
	["Skip"]     = nil,
}

local STABLE_DARKLUA = {
	generator = "dense",
	bundle = {
		modules_identifier = "__DIST",
		require_mode = { name = "luau", use_luau_configuration = true },
	},
	rules = {
		"convert_local_function_to_assign",
		"convert_index_to_field",
		"compute_expression",
		"filter_after_early_return",
		"group_local_assignment",
		"remove_comments",
		"remove_empty_do",
		"remove_debug_profiling",
		"remove_function_call_parens",
		"remove_nil_declaration",
		"remove_spaces",
		"remove_types",
		"remove_unused_if_branch",
		"remove_if_expression",
		"remove_unused_variable",
		"remove_unused_while",
		{
			rule = "rename_variables",
			include_functions = true,
			globals = { "$default", "$roblox" },
		},
	},
}

local UNMINIFIED_DARKLUA = {
	generator = "retain_lines",
	bundle = {
		modules_identifier = "__DIST",
		require_mode = { name = "luau", use_luau_configuration = true },
	},
	rules = {},
}

local RELEASE_FRAME = [=[--!nolint
--!nocheck
--!native
--!optimize 2

--[[
    This file was automatically generated with ProCMP + darklua.
    It is not intended for manual editing.
]]

_P = {
    genDate = __COMPOSER.Insert(__COMPOSER.genDate),
    cfg = __COMPOSER.Insert(__COMPOSER.cfg),
    vers = __COMPOSER.Insert(__COMPOSER.vers)
}

__COMPOSER.Insert(__COMPOSER.build)
]=]

local DEBUG_FRAME = [=[--!nolint
--!nocheck

--[[
    DEBUG BUILD — generated by ProCMP + darklua.
    Not for distribution.
]]

_P = {
    genDate = __COMPOSER.Insert(__COMPOSER.genDate),
    cfg = __COMPOSER.Insert(__COMPOSER.cfg),
    vers = __COMPOSER.Insert(__COMPOSER.vers)
}

__COMPOSER.Insert(__COMPOSER.build)
]=]

--// Private Methods

local function writeJson(path: string, data: any)
	fs.writeFile(path, serde.encode("json", data))
end

local function prompt(label: string, default: string?): string
	local suffix = default and ` [{default}]` or ""
	local val = io.prompt("text", label .. suffix)
	if (val == nil or val == "") and default then
		return default
	end
	return val or ""
end

local function ensureDirs(paths: { string })
	for _, p in ipairs(paths) do
		if not fs.isDir(p) then
			fs.writeDir(p)
		end
	end
end

local function appendGitignore(lines: { string })
	local existing = fs.isFile(".gitignore") and fs.readFile(".gitignore") or ""
	local toAdd: { string } = {}
	for _, line in ipairs(lines) do
		if not existing:find(line, 1, true) then
			table.insert(toAdd, line)
		end
	end
	if #toAdd > 0 then
		local addition = "\n# ProCMP\n" .. table.concat(toAdd, "\n") .. "\n"
		fs.writeFile(".gitignore", existing .. addition)
	end
end

--// Public Methods

local function run()
	ui.printInfo("ProCMP project initialiser")
	print("")

	local projectName = prompt("Project name", "my-project")
	local ghOwner = prompt("GitHub owner (leave blank to skip deployment config)", "")
	local ghRepo = ghOwner ~= "" and prompt("GitHub repository name", projectName) or ""

	print("")
	ui.printInfo("Select your preferred editor for release notes and output preview.")
	ui.printInfo("This will be saved to .pcmp.local.json (gitignored) — each team member sets their own.")
	print("")

	local editorIdx = io.prompt("select", "Release notes editor", EDITOR_OPTIONS)
	local editorPreset = EDITOR_PRESETS[EDITOR_OPTIONS[editorIdx]]

	local openIdx = io.prompt("select", "Open composed output in", EDITOR_OPTIONS)
	local openPreset = OPEN_PRESETS[EDITOR_OPTIONS[openIdx]]

	-- Build configs
	print("")
	local includeDebug   = io.prompt("confirm", "Include Debug build config?")
	local includeBeta    = io.prompt("confirm", "Include Beta build config?")
	local includeRelease = io.prompt("confirm", "Include Release build config?")

	-- Paths
	local inputPath  = prompt("Source entry point", "src/init.luau")
	local outBase    = prompt("Generated output base directory", "generated")

	-- Directories
	ensureDirs({
		"pipeline",
		"pipeline/frames",
		"pipeline/darklua",
		"src",
		outBase,
	})

	-- Build configs
	local buildConfigs = {}

	if includeDebug then
		table.insert(buildConfigs, {
			name = "Debug",
			input = inputPath,
			output = outBase .. "/debug/" .. projectName .. ".luau",
			frame = "pipeline/frames/debug.luau",
			darkluaConfig = "pipeline/darklua/unminified.json",
			promptVersion = false,
			promptDeploy = false,
		})
	end

	if includeBeta then
		table.insert(buildConfigs, {
			name = "Beta",
			input = inputPath,
			output = outBase .. "/beta/" .. projectName .. ".luau",
			frame = "pipeline/frames/release.luau",
			darkluaConfig = "pipeline/darklua/stable.json",
			promptVersion = true,
			versionFormat = "^v%d+%.%d+%.%d+",
			promptDeploy = ghOwner ~= "",
			prerelease = true,
			variants = includeBeta and {
				{
					name = "Beta-Unminified",
					darkluaConfig = "pipeline/darklua/unminified.json",
					output = outBase .. "/beta/" .. projectName .. "-unminified.luau",
				},
			} or nil,
		})
	end

	if includeRelease then
		table.insert(buildConfigs, {
			name = "Release",
			input = inputPath,
			output = outBase .. "/release/" .. projectName .. ".luau",
			frame = "pipeline/frames/release.luau",
			darkluaConfig = "pipeline/darklua/stable.json",
			promptVersion = true,
			versionFormat = "^v%d+%.%d+%.%d+",
			promptDeploy = ghOwner ~= "",
			prerelease = false,
			variants = includeRelease and {
				{
					name = "Release-Unminified",
					darkluaConfig = "pipeline/darklua/unminified.json",
					output = outBase .. "/release/" .. projectName .. "-unminified.luau",
				},
			} or nil,
		})
	end

	-- .pcmp.json
	local sharedConfig: { [string]: any } = {
		buildConfigs = buildConfigs,
	}

	if ghOwner ~= "" then
		sharedConfig.deployment = {
			github = {
				owner = ghOwner,
				repo = ghRepo,
				tokenEnvVar = "GITHUB_TOKEN",
			},
		}
	end

	writeJson("pipeline/.pcmp.json", sharedConfig)
	ui.printSuccess("Generated pipeline/.pcmp.json")

	-- .pcmp.local.json
	local localConfig: { [string]: any } = {}
	if editorPreset then
		localConfig.releaseNotesEditor = editorPreset
	end
	if openPreset then
		localConfig.openComposedOutput = openPreset
	end

	writeJson("pipeline/.pcmp.local.json", localConfig)
	ui.printSuccess("Generated pipeline/.pcmp.local.json")

	-- Frame
	fs.writeFile("pipeline/frames/release.luau", RELEASE_FRAME)
	fs.writeFile("pipeline/frames/debug.luau", DEBUG_FRAME)
	ui.printSuccess("Generated pipeline/frames/")

	-- Darklua
	writeJson("pipeline/darklua/stable.json", STABLE_DARKLUA)
	writeJson("pipeline/darklua/unminified.json", UNMINIFIED_DARKLUA)
	ui.printSuccess("Generated pipeline/darklua/")

	-- .env.example
	fs.writeFile(
		".env.example",
		"# GitHub token — fine-grained PAT (Contents: write, Metadata: read) or classic repo scope\n"
			.. "GITHUB_TOKEN=\"YOUR_TOKEN_HERE\"\n"
	)
	ui.printSuccess("Generated .env.example")

	-- .gitignore
	appendGitignore({
		"generated/",
		".env",
		"pipeline/.pcmp.local.json",
	})
	ui.printSuccess("Updated .gitignore")

	print("")
	ui.printSuccess("Project initialised!")
	print("")
	print("Next steps:")
	print("  1. Copy .env.example to .env and add your GitHub token")
	print("  2. Run: pcmp pipeline/.pcmp.json")
	print("")
	print("Your team members should run `pcmp init` in their own checkout to")
	print("set up their personal .pcmp.local.json with their editor preferences.")
end

return {
	run = run,
}
